{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (OpenOCD)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "serverpath": "/opt/homebrew/bin/openocd",
            "configFiles": [
                "interface/stlink.cfg",
                "target/stm32f4x.cfg"
            ],
            "executable": "${workspaceFolder}/build/blink",
            "device": "STM32F446RE",
            "svdFile": "${workspaceFolder}/.vscode/STM32F446.svd",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none"
        }
    ]
}
